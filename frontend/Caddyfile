zamp-invoice.duckdns.org {
    # Serve the React built static files
    root * /srv
    encode gzip
    
    # Try static files first, then fallback to index.html (SPA routing)
    try_files {path} {path}/ /index.html
    file_server

    # Strip /api prefix and proxy to the backend container
    handle_path /api/* {
        reverse_proxy http://backend:8000
    }
}
